<!-- Products Section -->
@{
    bool isFiltered = !string.IsNullOrEmpty(Context.Request.Query["search"]) ||
                      !string.IsNullOrEmpty(Context.Request.Query["cate"]) ||
                      !string.IsNullOrEmpty(Context.Request.Query["brandId"]) ||
                      !string.IsNullOrEmpty(Context.Request.Query["minPrice"]) ||
                          !string.IsNullOrEmpty(Context.Request.Query["maxPrice"]) ||
                          !string.IsNullOrEmpty(Context.Request.Query["categoryName"]) ||
                          !string.IsNullOrEmpty(Context.Request.Query["isfeatured"]) ||
                          !string.IsNullOrEmpty(Context.Request.Query["topselling"]) ||
                          !string.IsNullOrEmpty(Context.Request.Query["page"]);
    
    // Thêm tham số 'lightTitle' vào hàm
    async Task RenderProductSection(string boldTitle, string lightTitle, IEnumerable<Product> products, string queryString)
    {
        if (products != null && products.Any())
        {
            <section class="category-section mt-5 mb-5">
                <div class="container">
                    
                    <div class="d-flex justify-content-between align-items-baseline mb-4 flex-wrap">
                        <div class="d-flex align-items-baseline flex-wrap">
                            <h3 class="fw-bold mb-0" style="font-size: 28px; color: #1d1d1f; letter-spacing: -0.5px;">@boldTitle</h3>
                            <h3 class="fw-medium mb-0 ms-2" style="font-size: 28px; color: #86868b; letter-spacing: -0.5px;">@lightTitle</h3>
                        </div>
                        
                        <a href="/Home/TrangChu?@queryString" class="text-decoration-none text-dark mt-2 mt-md-0" style="font-size: 15px; font-weight: 500;">
                            Xem tất cả <i class="fas fa-chevron-right ms-1" style="font-size: 13px;"></i>
                        </a>
                    </div>
                    <div class="row">
                        @foreach (var item in products)
                        {
                            <div class="col-6 col-md-4 col-lg-3 mb-4">
                                @await Html.PartialAsync("_ProductCard", item)
                                @* --- ĐÃ MỞ MÃ NGUỒN CỦA THẺ SẢN PHẨM TẠI ĐÂY --- *@
                                <div class="product-card-modern fade-in h-100" data-product-id="@item.ProductId">

                                    @* Huy hiệu giảm giá hình tròn *@
                                    @if (item.Discount > 0)
                                    {
                                        <div class="discount-badge-circle">
                                            <span>Giảm</span>
                                            <span>@item.Discount%</span>
                                        </div>
                                    }

                                    @* Nút yêu thích *@
                                    <button type="button" class="wishlist-btn" onclick="toggleWishlist(this, @item.ProductId)" title="Thêm vào yêu thích">
                                        <i class="far fa-heart"></i>
                                    </button>

                                    <a href="/product/@item.ProductId" class="text-decoration-none">
                                        <div class="product-image-container">
                                            <img src="@(string.IsNullOrEmpty(item.ImagePr) ? "/images/default-product.png" : item.ImagePr.Split(';')[0])" alt="@item.ProductName" loading="lazy" />
                                        </div>
                                    </a>

                                    <div class="product-info">
                                        <a href="/product/@item.ProductId" class="text-decoration-none w-100">
                                            <h3 class="product-title">@item.ProductName</h3>
                                        </a>

                                        <div class="price-current">@string.Format("{0:N0}", item.SellingPrice * (1 - (item.Discount ?? 0) / 100)) VND</div>
                                        <div class="price-old" style="@(item.Discount > 0 ? "" : "visibility: hidden;")">@string.Format("{0:N0}", item.SellingPrice) VND</div>

                                        <a href="/product/@item.ProductId" class="btn btn-detail">Xem chi tiết</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }
    }
}

@if (isFiltered)
{
    <section>
        <h2 class="section-title">Kết quả tìm kiếm</h2>
        @if (Model != null && Model.Any())
        {
            <div class="product-grid">
                @foreach (var item in Model)
                {
                    <div class="product-card-modern fade-in" data-product-id="@item.ProductId">
                        @if (item.Discount > 0)
                        {
                            <div class="badge discount-badge">-@item.Discount%</div>
                        }
                        <button type="button" class="wishlist-btn" onclick="toggleWishlist(this, @item.ProductId)" title="Thêm vào yêu thích">
                            <i class="far fa-heart"></i>
                        </button>
                        <a href="/product/@item.ProductId" class="product-link">
                            <div class="product-image-container">
                                <img src="@(string.IsNullOrEmpty(item.ImagePr) ? "" : item.ImagePr.Split(';')[0])" alt="@item.ProductName" loading="lazy" />
                            </div>
                            <div class="product-info">
                                <h3 class="product-title">@item.ProductName</h3>
                                <div class="product-price">
                                    @if (item.Discount > 0)
                                    {
                                        <span class="text-primary fw-bold">@string.Format("{0:N0}", item.SellingPrice - (item.SellingPrice * item.Discount / 100)) ₫</span>
                                        <span class="text-muted text-decoration-line-through small ms-2">@string.Format("{0:N0}", item.SellingPrice) ₫</span>
                                    }
                                    else
                                    {
                                        <span class="text-primary fw-bold">@string.Format("{0:N0}", item.SellingPrice) ₫</span>
                                    }
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Phân trang -->
            @if (ViewBag.TotalPages > 1)
            {
                <div class="d-flex justify-content-center mt-5 w-100">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-lg shadow-sm">
                            @if (ViewBag.CurrentPage > 1)
                            {
                                var prevQuery = Context.Request.QueryString.Value ?? "?";
                                prevQuery = System.Text.RegularExpressions.Regex.Replace(prevQuery, @"(&|\?)page=\d+", "");
                                prevQuery += (prevQuery == "?" || prevQuery == "" ? "?" : "&") + "page=" + (ViewBag.CurrentPage - 1);
                                <li class="page-item">
                                    <a class="page-link" href="/Home/TrangChu@(prevQuery)">&laquo; Trước</a>
                                </li>
                            }

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                var query = Context.Request.QueryString.Value ?? "?";
                                query = System.Text.RegularExpressions.Regex.Replace(query, @"(&|\?)page=\d+", "");
                                query += (query == "?" || query == "" ? "?" : "&") + "page=" + i;

                                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" href="/Home/TrangChu@(query)">@i</a>
                                </li>
                            }

                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                var nextQuery = Context.Request.QueryString.Value ?? "?";
                                nextQuery = System.Text.RegularExpressions.Regex.Replace(nextQuery, @"(&|\?)page=\d+", "");
                                nextQuery += (nextQuery == "?" || nextQuery == "" ? "?" : "&") + "page=" + (ViewBag.CurrentPage + 1);
                                <li class="page-item">
                                    <a class="page-link" href="/Home/TrangChu@(nextQuery)">Sau &raquo;</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">Không tìm thấy sản phẩm nào phù hợp</h4>
                <p class="text-muted">Hãy thử điều chỉnh bộ lọc hoặc tìm kiếm với từ khóa khác</p>
            </div>
        }
    </section>
}
else
{
    await RenderProductSection("Sản phẩm nổi bật.", "Tinh hoa hội tụ.", ViewBag.FeaturedProducts as IEnumerable<Product>, "isfeatured=true");
    await RenderProductSection("Đang gây bão.", "Sự lựa chọn của số đông.", ViewBag.TopSellingProducts as IEnumerable<Product>, "topselling=true");
    await RenderProductSection("Smartphone đỉnh cao.", "Cả thế giới thu bé vừa bằng lòng bàn tay.", ViewBag.Phones as IEnumerable<Product>, "categoryName=Dien thoai");
    await RenderProductSection("Laptop.", "Hiệu năng bứt phá. Sẵn sàng cho mọi ý tưởng.", ViewBag.Laptops as IEnumerable<Product>, "categoryName=Laptop");
    await RenderProductSection("Máy tính bảng.", "Mỏng nhẹ tuyệt đối. Sáng tạo vô hạn.", ViewBag.Tablets as IEnumerable<Product>, "categoryName=May tinh bang");
    await RenderProductSection("Phụ kiện.", "Mảnh ghép hoàn hảo. Nâng tầm trải nghiệm.", ViewBag.Accessories as IEnumerable<Product>, "categoryName=Phu kien");
}

