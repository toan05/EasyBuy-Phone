<!-- Filter Section -->
<section class="filter-section">
    <h4 class="mb-3"><i class="fas fa-filter me-2"></i>Bộ lọc sản phẩm</h4>
    
    @* Đưa phần khai báo biến ra ngoài cùng để tránh xung đột ngữ cảnh C# *@
    @{
        var categories = ViewBag.Categories as List<EasyBuy.Models.Category> ?? new List<EasyBuy.Models.Category>();
        var brands = ViewBag.Brands as List<EasyBuy.Models.Brand> ?? new List<EasyBuy.Models.Brand>();
    }

    @using (Html.BeginForm("TrangChu", "Home", FormMethod.Get, new { @class = "filter-form" }))
    {
        <div class="filter-row"> 
            <div class="form-group">
                <label class="form-label">Danh mục</label>
                <select name="cate" class="form-control">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var c in categories)
                    {
                        if (Context.Request.Query["cate"] == c.CateId.ToString())
                        {
                            <option value="@c.CateId" selected>@c.CategoryName</option>
                        }
                        else
                        {
                            <option value="@c.CateId">@c.CategoryName</option>
                        }
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Thương hiệu</label>
                <select name="brandId" class="form-control">
                    <option value="">Tất cả thương hiệu</option>
                    @foreach (var b in brands)
                    {
                        if (Context.Request.Query["brandId"] == b.BrandId.ToString())
                        {
                            <option value="@b.BrandId" selected>@b.NameBrand</option>
                        }
                        else
                        {
                            <option value="@b.BrandId">@b.NameBrand</option>
                        }
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Giá từ</label>
                <input type="number" name="minPrice" class="form-control" placeholder="0" value="@Context.Request.Query["minPrice"]" />
            </div>
            
            <div class="form-group">
                <label class="form-label">Giá đến</label>
                <input type="number" name="maxPrice" class="form-control" placeholder="10000000" value="@Context.Request.Query["maxPrice"]" />
            </div>
            
            <div class="form-group align-self-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-2"></i>Áp dụng bộ lọc
                </button>
            </div>
        </div>
    }
</section>

