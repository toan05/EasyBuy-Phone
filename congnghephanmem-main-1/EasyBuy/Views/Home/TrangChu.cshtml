        <a href="/Home/TrangChu?cate=5" class="category-item-pill">
            <div class="category-pill-image-wrapper">
                <img src="/images/design_shop/tai-nghe.png" alt="Tai nghe" onerror="this.src='/images/design_shop/default.png'" loading="lazy" style="padding: 5px;">
            </div>
            <span class="category-pill-name">
