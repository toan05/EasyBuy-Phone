                <img src="/images/design_shop/may-tinh-bang.png" alt="Máy tính bảng" onerror="this.src='/images/design_shop/default.png'" loading="lazy" style="padding: 8px;">
            </div>
            <span class="category-pill-name">
                Máy tính bảng
            </span>
