@model EasyBuy.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
    Layout = "~/Areas/Admin/Views/Layout/_LayoutAdmin.cshtml";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-file-invoice"></i> Chi tiết đơn hàng #@Model.OrderId</h2>
        <a href="@Url.Action("ListOrders", "Orders", new { area = "Admin" })" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4 shadow">
                <div class="card-header bg-white fw-bold">Danh sách sản phẩm</div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td>@detail.Product?.ProductName</td>
                                    <td>@string.Format("{0:N0} đ", detail.UnitPrice)</td>
                                    <td>@detail.Quantity</td>
                                    <td class="text-danger fw-bold">@string.Format("{0:N0} đ", (detail.UnitPrice ?? 0) * (detail.Quantity ?? 0))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="mt-4 mb-4">
                @if (Model.Status == "Chờ xác nhận")
                {
                    <form asp-action="ConfirmOrder" asp-controller="Orders" asp-area="Admin" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.OrderId" />
                        <button type="submit" class="btn btn-success me-2"><i class="fas fa-check"></i> Xác nhận đơn</button>
                    </form>
                    <form asp-action="CancelOrder" asp-controller="Orders" asp-area="Admin" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.OrderId" />
                        <button type="submit" class="btn btn-danger me-2" onclick="return confirm('Bạn có chắc chắn hủy đơn này?');"><i class="fas fa-times"></i> Hủy đơn</button>
                    </form>
                }
                <a asp-action="PrintOrder" asp-controller="Orders" asp-area="Admin" asp-route-id="@Model.OrderId" target="_blank" class="btn btn-primary">
                    <i class="fas fa-print"></i> In đơn hàng (A5)
                </a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-4 shadow">
                <div class="card-header bg-white fw-bold">Thông tin đơn hàng</div>
                <div class="card-body">
                    <p><strong>Trạng thái:</strong> <span class="badge bg-info text-dark">@Model.Status</span></p>
                    <p><strong>Ngày đặt:</strong> @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Thanh toán:</strong> @Model.PaymentMethod?.MethodName</p>
                    <p><strong>Trạng thái thanh toán:</strong> @Model.StatusPayment</p>
                    <hr />
                    <p><strong>Khách hàng:</strong> @Model.User?.FullName</p>
                    <p><strong>Điện thoại:</strong> @Model.User?.Phone</p>
                    <p><strong>Giao đến:</strong> @(Model.Address?.FullAddress ?? "N/A")</p>
                    <hr />
                    <h4 class="text-danger">Tổng cộng: @string.Format("{0:N0} đ", Model.FinalTotal ?? Model.TotalAmount)</h4>
                </div>
            </div>
        </div>
    </div>
</div>