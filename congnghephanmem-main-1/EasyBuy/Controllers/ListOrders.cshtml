@model IEnumerable<EasyBuy.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    // Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; // Bỏ comment nếu dự án của bạn có tên Layout Admin riêng
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold m-0"><i class="fas fa-shopping-cart me-2"></i>Danh sách đơn hàng</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-center">Mã ĐH</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold">#@item.OrderId</td>
                                    <td>
                                        <span class="fw-bold d-block">@(item.User?.FullName ?? "Khách vãng lai")</span>
                                    </td>
                                    <td>@(item.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</td>
                                    <td class="text-danger fw-bold">@string.Format("{0:N0} đ", item.TotalAmount)</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@(item.PaymentMethod?.MethodName ?? "N/A")</span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.Status == "Chờ xác nhận")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ xác nhận</span>
                                        }
                                        else if (item.Status == "Đã xác nhận")
                                        {
                                            <span class="badge bg-primary px-3 py-2 rounded-pill">Đã xác nhận</span>
                                        }
                                        else if (item.Status == "Đã giao" || item.Status == "Hoàn thành")
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">Hoàn thành</span>
                                        }
                                        else if (item.Status == "Đã hủy")
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill">Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Status</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a href="/Admin/Orders/ViewOrderDetails/@item.OrderId" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i> Xem
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-box-open fa-2x mb-2 d-block"></i>
                                    Chưa có đơn hàng nào
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>