@model EasyBuy.Models.Voucher
@{
    ViewData["Title"] = "Chỉnh sửa Khuyến mãi";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.VoucherId" />
    <div class="form-group">
        <label>Mã voucher</label>
        <input class="form-control" name="code" value="@Model.Code" />
    </div>
    <div class="form-group">
        <label>Giảm giá (số tiền)</label>
        <input class="form-control" name="discountValue" type="number" step="0.01" value="@(Model.DiscountValue ?? 0)" />
    </div>
    <div class="form-group">
        <label>Ngày bắt đầu</label>
        <input class="form-control" name="startDate" type="date" value="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="form-group">
        <label>Ngày kết thúc</label>
        <input class="form-control" name="endDate" type="date" value="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="form-group">
        <label>Hoạt động</label>
        <select class="form-control" name="isActive">
            @if (Model.IsActive == true)
            {
                <option value="true" selected>Active</option>
                <option value="false">Inactive</option>
            }
            else
            {
                <option value="true">Active</option>
                <option value="false" selected>Inactive</option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
</form>
