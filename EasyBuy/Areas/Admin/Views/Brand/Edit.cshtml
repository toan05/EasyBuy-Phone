@model EasyBuy.Models.Brand

@{
    ViewData["Title"] = "Chỉnh sửa thương hiệu";
}

<h2>Chỉnh sửa thương hiệu</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@using (Html.BeginForm("Edit", "Brand", new { area = "Admin", id = Model.BrandId }, FormMethod.Post))
{
    <div class="mb-3">
        <label for="nameBrand" class="form-label">Tên thương hiệu</label>
        <input type="text" name="nameBrand" id="nameBrand" class="form-control" value="@Model.NameBrand" required />
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a href="@Url.Action("Index", "Brand", new { area = "Admin" })" class="btn btn-secondary">Trở về</a>
}
