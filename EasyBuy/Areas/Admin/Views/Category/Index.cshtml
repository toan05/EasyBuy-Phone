@model IEnumerable<EasyBuy.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<p>
    <a class="btn btn-primary" asp-action="Create">Thêm Danh mục</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Tên danh mục</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CateId</td>
                <td>@item.CategoryName</td>
                <td>
                    <a class="btn btn-sm btn-success" asp-action="Edit" asp-route-id="@item.CateId">Sửa</a>
                    <form asp-action="Delete" asp-route-id="@item.CateId" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa danh mục này?');">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
